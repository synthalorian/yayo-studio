<%= form_with model: [project, entry], class: "space-y-5" do |f| %>
  <div>
    <%= f.label :title, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :title, required: true,
          class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
  </div>

  <div>
    <%= f.label :content, class: "block text-sm font-medium mb-1" %>
    <%= f.rich_text_area :content,
          class: "w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)]" %>
  </div>

  <div>
    <%= f.label :entry_date, "Date", class: "block text-sm font-medium mb-1" %>
    <%= f.date_field :entry_date, value: entry.entry_date || Date.current,
          class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
  </div>

  <div>
    <%= f.label :tag_ids, "Tags", class: "block text-sm font-medium mb-1" %>
    <%= f.collection_check_boxes :tag_ids, Tag.alphabetical, :id, :name do |b| %>
      <label class="inline-flex items-center gap-2 mr-4 mb-2 cursor-pointer">
        <%= b.check_box class: "rounded border-[var(--color-border)] text-[var(--color-primary)] focus:ring-[var(--color-primary)]" %>
        <span class="text-sm"><%= b.text %></span>
      </label>
    <% end %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-6 py-3 rounded-xl font-medium bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-[var(--color-bg)] hover:opacity-90 transition-all cursor-pointer" %>
    <%= link_to "Cancel", entry.new_record? ? project_path(project) : [project, entry],
          class: "px-6 py-3 rounded-xl font-medium border border-[var(--color-border)] hover:border-[var(--color-text-muted)] transition-all text-center" %>
  </div>
<% end %>
