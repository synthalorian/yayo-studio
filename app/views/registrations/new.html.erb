<div class="w-full max-w-md mx-auto">
  <div class="text-center mb-8">
    <div class="text-5xl mb-4">🦞</div>
    <h1 class="text-3xl font-bold bg-gradient-to-r from-[#b388ff] to-[#00e5ff] bg-clip-text text-transparent">
      Join the Grid
    </h1>
    <p class="text-[#7a5f9a] mt-2">Create your Yayo Studio account</p>
  </div>

  <%= form_with model: @user, url: signup_path, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :name, "Name", class: "block text-sm font-medium text-[#e0d0f0] mb-1" %>
      <%= f.text_field :name, required: true,
            class: "w-full px-4 py-3 rounded-xl bg-[#1a0a2e] border border-[#3d2a5e] text-[#e0d0f0] placeholder-[#7a5f9a] focus:outline-none focus:border-[#b388ff] focus:ring-1 focus:ring-[#b388ff] transition-colors" %>
    </div>

    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-[#e0d0f0] mb-1" %>
      <%= f.email_field :email, required: true,
            class: "w-full px-4 py-3 rounded-xl bg-[#1a0a2e] border border-[#3d2a5e] text-[#e0d0f0] placeholder-[#7a5f9a] focus:outline-none focus:border-[#b388ff] focus:ring-1 focus:ring-[#b388ff] transition-colors" %>
    </div>

    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-[#e0d0f0] mb-1" %>
      <%= f.password_field :password, required: true,
            class: "w-full px-4 py-3 rounded-xl bg-[#1a0a2e] border border-[#3d2a5e] text-[#e0d0f0] placeholder-[#7a5f9a] focus:outline-none focus:border-[#b388ff] focus:ring-1 focus:ring-[#b388ff] transition-colors" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-[#e0d0f0] mb-1" %>
      <%= f.password_field :password_confirmation,
            class: "w-full px-4 py-3 rounded-xl bg-[#1a0a2e] border border-[#3d2a5e] text-[#e0d0f0] placeholder-[#7a5f9a] focus:outline-none focus:border-[#b388ff] focus:ring-1 focus:ring-[#b388ff] transition-colors" %>
    </div>

    <%= f.submit "Initialize",
          class: "w-full py-3 px-6 rounded-xl font-semibold bg-gradient-to-r from-[#b388ff] to-[#00e5ff] text-[#0a0a1a] hover:opacity-90 transition-all cursor-pointer" %>
  <% end %>

  <% if @user.errors.any? %>
    <div class="mt-4 p-4 rounded-xl border border-[#ff5252]/30 bg-[#ff5252]/10">
      <% @user.errors.full_messages.each do |msg| %>
        <p class="text-sm text-[#ff5252]">⚠ <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <p class="text-center mt-6 text-sm text-[#7a5f9a]">
    Already on the grid?
    <%= link_to "Sign in", login_path, class: "text-[#b388ff] hover:text-[#00e5ff] transition-colors" %>
  </p>
</div>
