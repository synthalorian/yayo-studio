<%= form_with model: project, class: "space-y-5" do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :name, required: true,
          class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
  </div>

  <div>
    <%= f.label :project_type_id, "Project Type", class: "block text-sm font-medium mb-1" %>
    <%= f.collection_select :project_type_id, ProjectType.ordered, :id, :name,
          { include_blank: "Select type..." },
          class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-medium mb-1" %>
    <%= f.select :status, Project::STATUSES.map { |s| [s.capitalize, s] }, { include_blank: "Select status..." },
          class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium mb-1" %>
    <%= f.text_area :description, rows: 4,
          class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :repo_url, "Repository URL", class: "block text-sm font-medium mb-1" %>
      <%= f.url_field :repo_url, placeholder: "https://github.com/...",
            class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
    </div>
    <div>
      <%= f.label :website_url, "Website URL", class: "block text-sm font-medium mb-1" %>
      <%= f.url_field :website_url, placeholder: "https://...",
            class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-6 py-3 rounded-xl font-medium bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-[var(--color-bg)] hover:opacity-90 transition-all cursor-pointer" %>
    <%= link_to "Cancel", project.new_record? ? projects_path : project,
          class: "px-6 py-3 rounded-xl font-medium border border-[var(--color-border)] hover:border-[var(--color-text-muted)] transition-all text-center" %>
  </div>
<% end %>
