<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Settings</h1>

  <%= form_with model: current_user, url: settings_path, method: :patch, class: "space-y-6" do |f| %>
    <!-- Profile -->
    <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
      <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
        <span>👤</span> Profile
      </h2>

      <div class="space-y-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium mb-1" %>
          <%= f.text_field :name, required: true,
                class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium mb-1" %>
          <%= f.email_field :email, required: true,
                class: "w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] focus:outline-none focus:border-[var(--color-primary)] focus:ring-1 focus:ring-[var(--color-primary)] transition-colors" %>
        </div>
      </div>
    </div>

    <!-- Theme selection -->
    <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
      <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
        <span>🎨</span> Theme
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <% @themes.each do |theme| %>
          <label class="cursor-pointer">
            <%= f.radio_button :theme_name, theme.name, class: "peer sr-only" %>
            <div class="p-3 rounded-xl border-2 border-[var(--color-border)] peer-checked:border-[var(--color-primary)] peer-checked:shadow-lg peer-checked:shadow-[var(--color-primary)]/20 transition-all hover:border-[var(--color-primary)]/50">
              <%= theme_card_preview(theme) %>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-sm font-medium"><%= theme.name %></span>
                <% if current_user.theme_name == theme.name %>
                  <span class="ml-auto text-[var(--color-primary)] text-xs">✓ Active</span>
                <% end %>
              </div>
              <div class="flex gap-1 mt-2">
                <% %w[primary secondary accent].each do |key| %>
                  <span class="w-4 h-4 rounded-full" style="background: <%= theme.colors[key] %>"></span>
                <% end %>
              </div>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <!-- Save -->
    <div class="flex items-center gap-3">
      <%= f.submit "Save Settings",
            class: "px-6 py-3 rounded-xl font-medium bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-[var(--color-bg)] hover:opacity-90 transition-all cursor-pointer" %>
    </div>
  <% end %>
</div>
